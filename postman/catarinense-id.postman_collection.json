    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.session_uuid) {",
              "  pm.collectionVariables.set(\"sessionUuid\", json.session_uuid);",
              "}"
            ]
