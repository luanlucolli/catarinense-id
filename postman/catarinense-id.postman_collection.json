{
  "info": {
    "_postman_id": "bb8a22ea-626f-4b0d-9302-cd269e2f71a2",
    "name": "Catarinense ID API",
    "description": "Collection para testar as rotas da API Auth Catarinense.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "appKey",
      "value": "SUA_APP_KEY",
      "type": "string"
    },
    {
      "key": "sessionUuid",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Ping",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ping",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "ping"
          ]
        },
        "description": "Health check da API."
      },
      "response": []
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.session_uuid) {",
              "  pm.collectionVariables.set(\"sessionUuid\", json.session_uuid);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-App-Key",
            "value": "{{appKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "login"
          ]
        },
        "description": "Autentica um usuário com base em username, password e X-App-Key."
      },
      "response": []
    },
    {
      "name": "Validate",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{sessionUuid}}"
          },
          {
            "key": "X-App-Key",
            "value": "{{appKey}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/validate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "validate"
          ]
        },
        "description": "Valida a sessao usando Authorization Bearer e X-App-Key."
      },
      "response": []
    },
    {
      "name": "Get Current User (Me)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{sessionUuid}}"
          },
          {
            "key": "X-App-Key",
            "value": "{{appKey}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "me"
          ]
        },
        "description": "Retorna os dados do usuario autenticado."
      },
      "response": []
    },
    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.collectionVariables.unset(\"sessionUuid\");"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{sessionUuid}}"
          },
          {
            "key": "X-App-Key",
            "value": "{{appKey}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "logout"
          ]
        },
        "description": "Finaliza a sessao autenticada atual."
      },
      "response": []
    },
    {
      "name": "Admin - Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{sessionUuid}}"
          },
          {
            "key": "X-App-Key",
            "value": "{{appKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"novo.usuario\",\n  \"password\": \"123456\",\n  \"is_admin\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ]
        },
        "description": "Cria um novo usuario. Requer sessao valida de um usuario admin."
      },
      "response": []
    }
  ]
}
